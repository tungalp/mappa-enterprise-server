    "version": "0.2.0",
    "configurations": [
        {
            "name": "SSO",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "sso.main:app",
                "--port",
                "33100",
                "--host",
                "0.0.0.0",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/apps/sso",
            "jinja": false,
            "justMyCode": true,
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/apps/sso/.venv/bin/python3",
            "env": {
                "PYTHONPATH": "/workspace"
            }
        },
        {
            "name": "Manage",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
