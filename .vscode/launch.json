        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "purpose": [
                "debug-test"
            ]
        },
    ],
    "compounds": [
        {
            "name": "Full Mapa",
            "configurations": [
                "SSO",
                "Manage",
                "Gateway",
                "Service",
                "Application",
                "Spatial"
            ],
            "stopAll": true,
            "preLaunchTask": "update-all-apps"
        }
    ]
