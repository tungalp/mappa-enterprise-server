    "version": "2.0.0",
    "tasks": [
        {
            "label": "sso-poetry-install",
            "type": "shell",
            "command": "poetry config virtualenvs.in-project true && poetry install && exit",
            "options": {
                "cwd": "${workspaceFolder}/apps/sso"
            }
        },
        {
