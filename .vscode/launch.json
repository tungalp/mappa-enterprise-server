            "name": "Service (Multi-Worker)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "service.main:app",
                "--port",
                "33102",
                "--host",
                "0.0.0.0",
                "--workers", "4",
                "--loop", "uvloop",
                "--http", "httptools",
                "--timeout-keep-alive", "5",
                "--limit-concurrency", "100",
                "--log-level", "warning"
            ],
            "cwd": "${workspaceFolder}/apps/service",
            "jinja": false,
            "justMyCode": false,
            "console": "integratedTerminal",
